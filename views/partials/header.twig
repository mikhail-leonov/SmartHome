<header class="app-header">
  <div class="container-fluid px-3 px-lg-4">
    <div class="d-flex align-items-center justify-content-between py-2 flex-wrap gap-2">
      <div class="d-flex align-items-center gap-3">
        <div>
          <div class="brand"><i class="bi bi-house-heart-fill me-1"></i>Smart<span class="dot">Home</span></div>
          <div class="brand-sub">automation console</div>
        </div>
      </div>

      <div class="d-flex align-items-center gap-2 flex-wrap">
        <span id="pill-mqtt" class="pill {{ mqttConnected ? 'on' : 'off' }}">
          <span class="ind"></span>
          <span class="txt" data-label="MQTT">MQTT {{ mqttConnected ? 'online' : 'offline' }}</span>
        </span>
        <span id="pill-db" class="pill {{ dbHealthy ? 'on' : 'off' }}">
          <span class="ind"></span>
          <span class="txt" data-label="DB">DB {{ dbHealthy ? 'online' : 'offline' }}</span>
        </span>
        <span id="pill-season" class="pill on">
          <i class="bi bi-thermometer-half"></i>
          <span class="txt">{{ season }}</span>
        </span>
      </div>
    </div>
  </div>
</header>
